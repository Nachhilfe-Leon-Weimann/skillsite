# Library .d.ts files in the virtual store (e.g. next-themes) resolve "react"
# types by walking up to the root node_modules. With the app moved into a
# workspace, @types/react is only linked inside apps/*, so hoist it (and the
# pnpm defaults) back to the root for TypeScript to find.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@types/react
public-hoist-pattern[]=@types/react-dom
